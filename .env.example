# harness-guard plugin environment configuration (TEMPLATE)
#
# Copy this file to .env inside this directory and fill in your values.
# The actual .env is gitignored — never commit real secrets.
#
# ─── Provider Configuration ──────────────────────────────────────────────────
# Choose a pre-defined provider preset, or configure custom details.
#
# Active provider. Options:
#   - glm     (Default, uses Z.AI / GLM-5.2)
#   - minimax (uses MiniMax-M3)
#   - juxin   (uses gemini-3.5-flash)
#   - custom  (allows manual BASE_URL / MODEL overrides)
#
# HARNESS_GUARD_PROVIDER=glm

# ─── Custom Endpoint Overrides ───────────────────────────────────────────────
# Only needed if HARNESS_GUARD_PROVIDER is set to "custom", or to override
# specific parts of a pre-defined preset.
#
# Base URL for OpenAI-compatible chat completions endpoint.
# HARNESS_GUARD_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
#
# Model name to use for review calls.
# HARNESS_GUARD_MODEL=glm-5.2

# ─── Authentication ────────────────────────────────────────────────────────
# API key for the review endpoint.
# Resolution order:
#   1. HARNESS_GUARD_API_KEY  (plugin-specific, recommended)
#   2. ZAI_API_KEY            (Z.AI / GLM fallback)
#   3. GLM_API_KEY            (GLM fallback)
#   4. MINIMAX_CN_API_KEY     (Minimax fallback)
#   5. JUXIN_GEMINI_API_KEY   (Juxin fallback)
#
# HARNESS_GUARD_API_KEY=your-key-here

# ─── Tuning ────────────────────────────────────────────────────────────────
# Review request timeout in seconds (integer).
# Default: 60
# HARNESS_GUARD_TIMEOUT_S=60
#
# Max audit-trail characters sent to the review prompt (integer).
# Default: 4000
# HARNESS_GUARD_MAX_AUDIT_TRAIL_CHARS=4000

# ─── Kill switch ───────────────────────────────────────────────────────────
# Set to any truthy value (1, true, yes, on) to disable the plugin entirely.
# HARNESS_GUARD_DISABLE=0
