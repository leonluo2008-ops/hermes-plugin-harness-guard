# harness-guard plugin environment configuration (TEMPLATE)
#
# Copy this file to ~/.hermes/.env and fill in your values.
# This file (.env.example) is committed to the repo for reference.
# The actual .env is gitignored — never commit real secrets.
#
# ─── Authentication ────────────────────────────────────────────────────────
# API key for the review endpoint. Resolution order:
#   1. HARNESS_GUARD_API_KEY  (plugin-specific, recommended)
#   2. ZAI_API_KEY            (Z.AI / GLM, backward compat with v1)
#   3. GLM_API_KEY            (alt GLM naming)
# Set any ONE of these. The first one found wins.
#
# Example — Z.AI / GLM-5.2 (default endpoint):
# ZAI_API_KEY=sk-your-zai-key-here
#
# Example — any OpenAI-compatible provider (e.g. jxincm.cn, self-hosted):
# HARNESS_GUARD_API_KEY=sk-your-key-here

# ─── Endpoint ──────────────────────────────────────────────────────────────
# Base URL for OpenAI-compatible chat completions endpoint.
# (Plugin appends /chat/completions automatically.)
#
# Default (Z.AI coding endpoint):
# HARNESS_GUARD_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
#
# Self-test a custom endpoint before using it:
#   curl -X POST "${HARNESS_GUARD_BASE_URL}/chat/completions" \
#        -H "Authorization: Bearer ${HARNESS_GUARD_API_KEY}" \
#        -H "Content-Type: application/json" \
#        -d '{"model":"'"${HARNESS_GUARD_MODEL}"'","messages":[{"role":"user","content":"hi"}],"max_tokens":10}'

# ─── Model ─────────────────────────────────────────────────────────────────
# Model name to use for review calls.
# Default: glm-5.2
# HARNESS_GUARD_MODEL=glm-5.2

# ─── Tuning ────────────────────────────────────────────────────────────────
# Review request timeout in seconds (integer).
# Default: 60
# HARNESS_GUARD_TIMEOUT_S=60

# Max audit-trail characters sent to the review prompt (integer).
# Default: 4000 — keeps prompt size bounded for large sessions.
# HARNESS_GUARD_MAX_AUDIT_TRAIL_CHARS=4000

# ─── Kill switch ───────────────────────────────────────────────────────────
# Set to any truthy value (1, true, yes, on) to disable the plugin
# without editing config.yaml. Fail-open: agent runs unmonitored.
# HARNESS_GUARD_DISABLE=0
